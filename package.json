{
  "name": "lyricfloat",
  "version": "1.0.0",
  "type": "module",
  "description": "Floating synced lyrics overlay",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "package": "electron-vite build && electron-builder"
  },
  "dependencies": {
    "colorthief": "^2.4.0",
    "electron-store": "^8.2.0",
    "lucide-react": "^1.14.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "electron": "^29.1.4",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.1.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.5"
  },
  "build": {
    "appId": "com.lyricfloat.app",
    "productName": "LyricFloat",
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    },
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png",
        "filter": ["**/*"]
      }
    ]
  }
}
